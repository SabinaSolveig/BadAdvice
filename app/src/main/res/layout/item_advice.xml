<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.AdviceApp.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/margin_small">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/iv_advice_image"
            android:layout_width="match_parent"
            android:layout_height="@dimen/image_size_medium"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="@color/gray_light"/>

        <TextView
            android:id="@+id/tv_day"
            style="@style/AdviceDayText"
            android:paddingTop="@dimen/padding_small"
            android:paddingStart="@dimen/padding_small"
            android:paddingEnd="@dimen/padding_small"
            android:text="@string/day_format"/>

        <TextView
            android:id="@+id/tv_title"
            style="@style/AdviceTitleText"
            android:paddingHorizontal="@dimen/padding_small"
            android:paddingTop="@dimen/padding_small"
            android:text="@string/advice_title" />

        <TextView
            android:id="@+id/tv_short_description"
            style="@style/AdviceDescriptionText"
            android:padding="@dimen/padding_small"
            android:text="string/advice_detail_title"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>