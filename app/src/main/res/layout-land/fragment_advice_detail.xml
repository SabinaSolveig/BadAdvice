<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="@dimen/padding_medium"
    android:background="@color/white">

    <LinearLayout
        style="@style/HorizontalDetailContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_full_image"
            style="@style/HorizontalDetailImage"/>

        <LinearLayout
            style="@style/HorizontalDetailTextContainer"
            android:layout_width="@dimen/padding_zero"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_day_title"
                style="@style/HorizontalDetailDayText"
                android:text="@string/day_format"/>

            <TextView
                android:id="@+id/tv_title"
                style="@style/HorizontalDetailTitleText"
                android:text="@string/advice_title" />

            <TextView
                android:id="@+id/tv_full_description"
                style="@style/HorizontalDetailDescriptionText"
                android:text="@string/advice_detail_title" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>