<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LandAdviceTitleText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_size_title_medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:paddingHorizontal">@dimen/padding_small</item>
        <item name="android:paddingTop">@dimen/padding_small</item>
    </style>

    <style name="LandAdviceDescriptionText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/gray_dark</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:padding">@dimen/padding_small</item>
    </style>

    <style name="HorizontalDetailContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">@dimen/padding_small</item>
    </style>

    <style name="HorizontalDetailImage">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:adjustViewBounds">true</item>
        <item name="android:layout_marginEnd">@dimen/margin_medium</item>
        <item name="android:maxHeight">@dimen/image_max_height</item>
        <item name="android:background">@color/gray_light</item>
    </style>

    <style name="HorizontalDetailTextContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">@dimen/padding_small</item>
    </style>

    <style name="HorizontalDetailDayText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_size_day</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/indigo_500</item>
        <item name="android:paddingBottom">@dimen/padding_small</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="HorizontalDetailTitleText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_size_title_large</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingBottom">@dimen/padding_medium</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <style name="HorizontalDetailDescriptionText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_size_body_large</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
        <item name="android:paddingTop">@dimen/padding_small</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>